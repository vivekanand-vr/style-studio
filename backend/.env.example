# Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Docker local (default):
MONGODB_URI=mongodb://admin:password123@localhost:27017/stylestudio?authSource=admin

# MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/stylestudio?retryWrites=true&w=majority

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── JWT (Phase 2 — Auth) ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Amazon Product Advertising API (PA API 5.0) ─────────────────────────────
# Sign up at: https://affiliate-program.amazon.in/
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.in
AMAZON_REGION=eu-west-1

# ─── Flipkart Affiliate API ───────────────────────────────────────────────────
# Sign up at: https://affiliate.flipkart.com/
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# ─── OpenAI (AI features) ─────────────────────────────────────────────────────
# Sign up at: https://platform.openai.com/
OPENAI_API_KEY=

# ─── Cloudinary (Image backup) ────────────────────────────────────────────────
# Sign up at: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
